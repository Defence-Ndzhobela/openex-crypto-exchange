# Supabase PostgreSQL connection values
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.onzbfmwknjuskmwyqtgn
DB_PASSWORD=replace-with-your-password

# Full JDBC URL for Spring Boot (sslmode=require is required by Supabase)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.onzbfmwknjuskmwyqtgn
SPRING_DATASOURCE_PASSWORD=replace-with-your-password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Optional JPA defaults
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
